{
  "include": ["src"],
  "exclude": ["tests", "logs", "dist", "build", "**/node_modules", "**/__pycache__", "**/.*"],
  "enableTypeIgnoreComments": true,
  "reportAttributeAccessIssue": "none",
  "reportMissingTypeStubs": "none",
  "reportPrivateImportUsage": "none",
  "pythonVersion": "3.11",
  "typeCheckingMode": "basic"
}
